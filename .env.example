# Copy this file to .env and fill in your real API keys.
# The .env file is listed in .gitignore so it will never be committed.

# Get a free key at https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Translation is handled by MyMemory (https://mymemory.translated.net).
# It is completely free and requires no account or API key.
# No additional environment variables needed for translation.

# ── ElevenLabs TTS (PR 5) ────────────────────────────────────────────────────
# Get your key at https://elevenlabs.io (free tier available).
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: choose which ElevenLabs voice to use for each output language.
# Find voice IDs in the ElevenLabs dashboard (Voice Library → copy ID).
# If these are not set, a built-in default voice is used for all languages.
ELEVENLABS_VOICE_ID_EN=your_english_voice_id_here
ELEVENLABS_VOICE_ID_DE=your_german_voice_id_here

# Optional: single fallback voice used when the language-specific ones above
# are not set (takes priority over the hard-coded default).
# ELEVENLABS_VOICE_ID=your_fallback_voice_id_here
