# Copy this file to .env and fill in your real API keys.
# The .env file is listed in .gitignore so it will never be committed.

# Get a free key at https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# LibreTranslate (free, no account needed for the public instance).
# Leave LIBRETRANSLATE_URL unset to use the default public server.
# If you self-host LibreTranslate, point this at your own server.
# LIBRETRANSLATE_URL=https://libretranslate.com
# LIBRETRANSLATE_API_KEY=   ← only needed if your server requires it
